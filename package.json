{
  "name": "ai-money-mentor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:python": "cd backend && pip install fastapi uvicorn pydantic pandas pyxirr PyPDF2 streamlit requests && python -m uvicorn main:app --reload --port 8000",
    "dev:streamlit": "cd backend/auditor_agent/streamlit_app && streamlit run app.py --server.headless true",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:python\" \"npm run dev:streamlit\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@langchain/core": "^1.1.34",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.2",
    "typescript": "^5"
  }
}
