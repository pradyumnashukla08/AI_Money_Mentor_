datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth Requirements ──────────────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts          Account[]
  sessions          Session[]
  chatSessions      ChatSession[]
  notifications     Notification[]
  documents         Document[]
  financialProfile  FinancialProfile?
  agentMemories     AgentMemory[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── AI Money Mentor App Requirements ───────────────────────────────────────

model ChatSession {
  id          String    @id @default(cuid())
  userId      String
  title       String    @default("New Chat")
  activeAgent String    @default("manager")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  
  @@index([userId])
}

model Message {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String      // "user" or "agent" or "system"
  content       String
  agentId       String?     // Which agent handled this
  timestamp     DateTime    @default(now())
  
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  
  @@index([chatSessionId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // e.g. "alert", "insight", "reminder"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  size      Int
  url       String?  // the path/url where the document is physically stored
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FinancialProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  monthlyIncome Float    @default(0)
  totalAssets   Float    @default(0)
  riskTolerance String   @default("moderate") // "low", "moderate", "high"
  goals         String   @default("")         // JSON array string of goals or free text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentMemory {
  id         String   @id @default(cuid())
  userId     String
  topic      String   // topic or category of memory
  memoryData String   // Content of memory
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
